{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://musicliteracyhub.org/schemas/music-concept-question-bank-1.0.json",
  "title": "Music Literacy Hub Music Concept Question Bank",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bankType",
    "level",
    "source",
    "questions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "bankType": {
      "const": "music-concept-questions"
    },
    "level": {
      "enum": [
        "National 3",
        "National 4",
        "National 5",
        "Higher",
        "Advanced Higher"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "knowledgeBankFile",
        "knowledgeBankSchemaVersion",
        "knowledgeBankSha256"
      ],
      "properties": {
        "knowledgeBankFile": {
          "const": "Music_Concept_Knowledge_Bank_Ultimate_Codex_Edition.json"
        },
        "knowledgeBankSchemaVersion": {
          "const": "5.0"
        },
        "knowledgeBankSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/question"
      }
    }
  },
  "$defs": {
    "answer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text",
        "correct"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "correct": {
          "type": "boolean"
        },
        "featureOfConceptId": {
          "type": "string",
          "pattern": "^MC-[0-9]{4}$"
        }
      }
    },
    "literacyLink": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "relationship",
        "targets",
        "targetLiteracyIds"
      ],
      "properties": {
        "relationship": {
          "type": "string",
          "minLength": 1
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/literacyTarget"
          }
        },
        "targetLiteracyIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "literacyTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceFile",
        "localIds",
        "matchKind"
      ],
      "properties": {
        "sourceFile": {
          "type": "string",
          "minLength": 1
        },
        "localIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "matchKind": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "level",
        "category",
        "categories",
        "conceptId",
        "concept",
        "factId",
        "supportingFactIds",
        "senseId",
        "senseContext",
        "comparisonGroupId",
        "difficulty",
        "questionType",
        "answerMode",
        "question",
        "answers",
        "hint",
        "hintFactId",
        "explanation",
        "literacyLink"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^MCQ-(N3|N4|N5|H|AH)-MC[0-9]{4}-F[0-9]{2}-(E|M|H)-[0-9]{3}$"
        },
        "level": {
          "enum": [
            "National 3",
            "National 4",
            "National 5",
            "Higher",
            "Advanced Higher"
          ]
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "categories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "conceptId": {
          "type": "string",
          "pattern": "^MC-[0-9]{4}$"
        },
        "concept": {
          "type": "string",
          "minLength": 1
        },
        "factId": {
          "type": "string",
          "pattern": "^MC-[0-9]{4}-F[0-9]{2}$"
        },
        "supportingFactIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^MC-[0-9]{4}-F[0-9]{2}$"
          },
          "uniqueItems": true
        },
        "senseId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^MC-[0-9]{4}-S[0-9]{2}$"
        },
        "senseContext": {
          "type": [
            "string",
            "null"
          ]
        },
        "comparisonGroupId": {
          "type": [
            "string",
            "null"
          ]
        },
        "difficulty": {
          "enum": [
            "Easy",
            "Medium",
            "Hard"
          ]
        },
        "questionType": {
          "type": "string",
          "minLength": 1
        },
        "answerMode": {
          "enum": [
            "concept",
            "not_feature",
            "custom"
          ]
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "answers": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/answer"
          }
        },
        "hint": {
          "type": "string",
          "minLength": 1
        },
        "hintFactId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^MC-[0-9]{4}-F[0-9]{2}$"
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "featureSourceConceptId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^MC-[0-9]{4}$"
        },
        "literacyLink": {
          "$ref": "#/$defs/literacyLink"
        }
      }
    }
  }
}
